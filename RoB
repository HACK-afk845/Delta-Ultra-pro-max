local function UpdatePlayerList()
    for _, child in pairs(PlayerScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, p in pairs(playersService:GetPlayers()) do
        if p ~= localPlayer then
            local pBtn = Instance.new("TextButton", PlayerScroll)
            pBtn.Size = UDim2.new(1, -15, 0, 30) pBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            pBtn.Text = p.Name pBtn.TextColor3 = Color3.new(1, 1, 1) pBtn.Font = Enum.Font.Gotham pBtn.TextSize = 13
            Instance.new("UICorner", pBtn)
            
            pBtn.MouseButton1Click:Connect(function()
                playClick()
                SelectedPlayerLabel.Text = "المستهدف الحالي: " .. p.Name
                local pfx = PrefixInput.Text if pfx == "" then pfx = ";" end
                CmdInput.Text = pfx.."logs "..p.Name.." "..pfx.."nv "..p.Name.." "..pfx.."clogs "..p.Name.." "..pfx.."fling "..p.Name.." "..pfx.."ice "..p.Name.." "..pfx.."jc "..p.Name.." "..pfx.."kill "..p.Name
                StatusBar.Text = " [i] تم تجهيز سلسلة النسخ للاعب: " .. p.Name
                StatusBar.TextColor3 = Color3.fromRGB(255, 255, 0)
            end)
        end
    end
    PlayerScroll.CanvasSize = UDim2.new(0, 0, 0, PlayerListLayout.AbsoluteContentSize.Y + 10)
end

