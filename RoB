-- رسالة الترحيب بالعربي
local function Welcome()
    local welcomeLabel = Instance.new("TextLabel", sg)
    welcomeLabel.Size = UDim2.new(0, 500, 0, 100)
    welcomeLabel.Position = UDim2.new(0.5, -250, 0.4, 0)
    welcomeLabel.BackgroundTransparency = 1
    welcomeLabel.Text = "تم تشغيل النظام بنجاح"
    welcomeLabel.Font = Enum.Font.GothamBlack
    welcomeLabel.TextSize = 40
    task.spawn(function()
        local start = tick()
        while tick() - start < 5 do
            welcomeLabel.TextColor3 = Color3.fromHSV(tick() % 5 / 5, 1, 1)
            task.wait()
        end
        welcomeLabel:Destroy()
    end)
end
task.spawn(Welcome)

