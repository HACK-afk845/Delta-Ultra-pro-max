-- زر الـ Spam يفتح خانة إدخال، تكتب فيها أي كلام عربي
AddButton("Custom Chat Spam", function()
    local input = Instance.new("TextBox", MainFrame)
    input.Size = UDim2.new(0, 300, 0, 50)
    input.Position = UDim2.new(0.5, -150, 0.5, -25)
    input.PlaceholderText = "اكتب الرسالة هنا..."
    local btn = Instance.new("TextButton", input)
    btn.Size = UDim2.new(0, 100, 0, 30)
    btn.Position = UDim2.new(0.5, -50, 1, 5)
    btn.Text = "ارسال"
    btn.MouseButton1Click:Connect(function()
        local msg = input.Text
        for i = 1, 5 do
            if textChatService.ChatVersion == Enum.ChatVersion.TextChatService then
                textChatService.TextChannels.RBXGeneral:SendAsync(msg)
            else
                game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(msg, "All")
            end
            task.wait(0.5)
        end
        input:Destroy()
    end)
end)

