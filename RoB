AddMenuButton("حمايه 🛡️ (تنظيف شامل)", function()
    local cleanCount = 0
    local targets = {"logs", "nv", "cmdbar", "clogs", "hdadminhdclient", "hdadmin"}
    local function ExecutionClean(parent)
        for _, obj in pairs(parent:GetChildren()) do
            local found = false
            for _, name in pairs(targets) do if obj.Name:lower():find(name) then found = true break end end
            if found then obj:Destroy() cleanCount = cleanCount + 1 else pcall(function() ExecutionClean(obj) end) end
        end
    end
    ExecutionClean(workspace) ExecutionClean(localPlayer.PlayerGui)
end)

