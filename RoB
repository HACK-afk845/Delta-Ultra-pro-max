-- [ ⚙️ سكربتك الأصلي المعتمد بالكامل بدون أي تعديل في منطقه ]
local function invokeHDCommand(command)
	if not command or command == "" then return end
	
	-- رصد العلامة الأولى المدخلة بواسطة اللاعب
	local firstChar = string.sub(command, 1, 1)
	local allowedPrefixes = { [";"] = true, [":"] = true, ["?"] = true, ["."] = true, ["!"] = true, ["/"] = true, ["+"] = true, ["$"] = true, ["@"] = true }
	
	-- إذا لم يكن هناك بادئة من القائمة المسموحة، يتم إجبار السكربت على وضع الفاصلة المنقوطة الافتراضية
	if not allowedPrefixes[firstChar] then
		command = ";" .. command
	end

	if RequestCommandSilent and RequestCommandSilent:IsA("RemoteFunction") then
		pcall(function()
			RequestCommandSilent:InvokeServer(command)
		end)
	else
		-- خطة طوارئ بديلة للإرسال عبر الشات العادي إذا تعطل الـ Remote الأساسي لماب معين
		local ChatService = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
		if ChatService then
			local SayMessageRequest = ChatService:FindFirstChild("SayMessageRequest")
			if SayMessageRequest then
				pcall(function()
					SayMessageRequest:FireServer(command, "All")
				end)
			end
		end
	end
end

